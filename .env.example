# Variables de entorno del dashboard. En local copia este archivo a `.env`
# y rellena los valores. En Render se configuran desde el panel "Environment".

# ===== Secrets =====
# Clave de OpenAI para el chatbot y los informes con análisis automático.
OPENAI_API_KEY=sk-tu-clave-aqui

# ===== Autenticación =====
# Si estos dos están definidos, el dashboard pedirá login Basic Auth (navegador).
# Si NO están definidos (caso típico en local), no hay auth.
DASH_USER=admin
DASH_PASS=cambiala-por-una-larga

# ===== Configuración =====
# Puerto local. Render inyecta su propio PORT automáticamente.
PORT=7777

# Cada cuántas horas re-descargar los datos del INE en el arranque.
# 504 = 3 semanas. El INE publica las series mensualmente, no hace falta más.
TURISMO_REFRESH_HORAS=504

# Opcional: ruta a informes de ejemplo (Word/PDF). Por defecto: Desktop/Peñiscola/Informes/2025
# INFORMES_RESIDUOS_PATH=C:\Users\touri\Desktop\Peñiscola\Informes\2025
